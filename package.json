{
  "name": "rtp-verification-platform",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @rtp/api dev\" \"pnpm --filter @rtp/web dev\" \"pnpm --filter @rtp/api inngest:dev\"",
    "build": "pnpm --filter @rtp/game-schema build && pnpm --filter @rtp/shared-types build && pnpm --filter @rtp/api build && pnpm --filter @rtp/web build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @rtp/api db:migrate",
    "db:seed": "pnpm --filter @rtp/api db:seed",
    "db:studio": "pnpm --filter @rtp/api db:studio"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.7.3"
    }
  }
}
